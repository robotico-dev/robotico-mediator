<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Robotico.Mediator.Tests.Generated</RootNamespace>
    <AssemblyName>Robotico.Mediator.Tests.Generated</AssemblyName>
    <PackageId>Robotico.Mediator.Tests.Generated</PackageId>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- CA1707/CA1515: Test naming and discovery. CA2007: Test code may use plain await. CA1062: Generated test request objects. IDE0005: Requires GenerateDocumentationFile when enabled; generated tests do not generate docs. -->
    <NoWarn>$(NoWarn);CA1707;CA1515;IDE0005</NoWarn>
    <!-- Generated test code; no XML doc requirement. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Robotico.Mediator\Robotico.Mediator.csproj" />
    <!-- Source generator runs in this project; ReferenceOutputAssembly=false so we only get generated source, not the analyzer DLL as a runtime ref -->
    <ProjectReference Include="..\..\src\Robotico.Mediator.SourceGenerator\Robotico.Mediator.SourceGenerator.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
  </ItemGroup>
</Project>
